<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.FournisseurFormController"
      styleClass="modal-card" spacing="0"
      maxWidth="520" minWidth="480" maxHeight="300" >

    <!-- ══ HEADER ══ -->
    <HBox styleClass="modal-header" alignment="CENTER_LEFT" spacing="12">
        <StackPane style="-fx-background-color:#e8f0fb;-fx-background-radius:8;
                          -fx-min-width:36px;-fx-max-width:36px;
                          -fx-min-height:36px;-fx-max-height:36px;-fx-alignment:center;">
            <FontIcon iconLiteral="mdi2t-truck-outline" iconSize="18"
                      style="-fx-icon-color:#0154a6;"/>
        </StackPane>
        <Label fx:id="formTitle" text="Nouveau fournisseur"
               styleClass="modal-title" HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="topbar-icon-btn"
                style="-fx-font-size:14px;">
            <graphic><FontIcon iconLiteral="mdi2c-close" iconSize="16"/></graphic>
        </Button>
    </HBox>

    <!-- ══ BODY ══ -->
    <VBox styleClass="modal-body" spacing="16">

        <!-- Nom -->
        <VBox spacing="4">
            <Label text="Nom du fournisseur *" styleClass="form-label"/>
            <TextField fx:id="nomField" styleClass="form-input"
                       promptText="Ex: Dell Technologies"/>
            <Label fx:id="errNom" styleClass="field-error"
                   visible="false" managed="false"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="4">
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" styleClass="form-input"
                       promptText="contact@fournisseur.tn"/>
            <Label fx:id="errEmail" styleClass="field-error"
                   visible="false" managed="false"/>
        </VBox>

        <!-- Téléphone -->
        <VBox spacing="4">
            <Label text="Téléphone" styleClass="form-label"/>
            <TextField fx:id="telephoneField" styleClass="form-input"
                       promptText="+216 71 000 000"/>
            <Label fx:id="errTelephone" styleClass="field-error"
                   visible="false" managed="false"/>
        </VBox>

        <!-- Adresse -->
        <VBox spacing="4">
            <Label text="Adresse" styleClass="form-label"/>
            <TextField fx:id="adresseField" styleClass="form-input"
                       promptText="Ex: Les Berges du Lac, Tunis"/>
        </VBox>

        <!-- Spécialité -->
        <VBox spacing="4">
            <Label text="Spécialité" styleClass="form-label"/>
            <ComboBox fx:id="specialiteCombo" styleClass="filter-combo"
                      maxWidth="Infinity" editable="true"
                      promptText="Choisir ou saisir une spécialité"/>
        </VBox>

    </VBox>

    <!-- ══ FOOTER ══ -->
    <HBox styleClass="modal-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" styleClass="btn-secondary"
                onAction="#handleCancel" style="-fx-padding:9 24;"/>
        <Button fx:id="saveBtn" styleClass="btn-primary"
                onAction="#handleSave" style="-fx-padding:9 24;">
            <graphic>
                <HBox spacing="8" alignment="CENTER">
                    <FontIcon fx:id="saveIcon" iconLiteral="mdi2c-check" iconSize="14"/>
                    <Label fx:id="saveBtnLabel" text="Enregistrer"
                           style="-fx-text-fill:white;-fx-font-weight:bold;"/>
                </HBox>
            </graphic>
        </Button>
    </HBox>

</VBox>
