<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:id="panelRoot"
      fx:controller="org.example.controllers.NotificationPanelController"
      style="-fx-background-color:white;-fx-background-radius:12;
             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),20,0,0,6);
             -fx-border-color:#e2e8f0;-fx-border-radius:12;-fx-border-width:1;"
      prefWidth="250" maxHeight="520" maxWidth="450">

    <!-- HEADER -->
    <HBox style="-fx-padding:16 18 12 18;-fx-border-color:transparent transparent #f3f4f6 transparent;-fx-border-width:0 0 1 0;"
          alignment="CENTER_LEFT" spacing="8">
        <Label text="🔔 " style="-fx-font-size: 18px; -fx-text-fill: #0154a6;"/>
        <Label text="Notifications" styleClass="modal-title"
               style="-fx-font-size:15px;" HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text=""
               style="-fx-font-size:11px;-fx-text-fill:#d97706;"/>
        <Button fx:id="btnToutMarquer" text="Tout marquer lu"
                styleClass="btn-secondary"
                onAction="#handleToutMarquer"
                style="-fx-font-size:11px;-fx-padding:4 10;"
                visible="false" managed="false"/>
        <Button styleClass="topbar-icon-btn" onAction="#handleFermer"
                style="-fx-font-size:13px;-fx-padding:4;">
            <graphic><FontIcon iconLiteral="mdi2c-close" iconSize="14"/></graphic>
        </Button>
    </HBox>

    <!-- LISTE notifications (scrollable) -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:transparent;"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox fx:id="listeContainer" spacing="0">

            <!-- Message si vide -->
            <VBox fx:id="emptyLabel" alignment="CENTER" spacing="12"
                  style="-fx-padding:40 0;" visible="false" managed="false">
                <FontIcon iconLiteral="mdi2b-bell-off-outline" iconSize="36"
                          style="-fx-icon-color:#d1d5db;"/>
                <Label text="Aucune notification"
                       style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#9ca3af;"/>
                <Label text="Vous etes a jour !"
                       style="-fx-font-size:12px;-fx-text-fill:#d1d5db;"/>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
